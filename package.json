{
  "name": "nekocode",
  "version": "0.2.1",
  "description": "AI-powered coding assistant desktop app",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "bun run verify:patches && electron-vite build",
    "preview": "electron-vite preview",
    "package": "bun run verify:patches && electron-vite build && electron-builder --win",
    "package:mac": "bun run verify:patches && electron-vite build && electron-builder --mac",
    "package:linux": "bun run verify:patches && electron-vite build && electron-builder --linux",
    "package:all": "bun run verify:patches && electron-vite build && electron-builder -mwl",
    "release": "bun run verify:patches && electron-vite build && electron-builder --win --publish always",
    "postinstall": "patch-package",
    "verify:patches": "node ./scripts/verify-patches.cjs",
    "version:up": "node ./scripts/auto-upversion.cjs",
    "version:up:dry": "node ./scripts/auto-upversion.cjs --dry-run",
    "lint": "eslint --ext .ts,.tsx ./src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^0.64.0",
    "@tanstack/react-virtual": "^3.13.23",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.0",
    "shiki": "^3.2.1",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "electron": "^34.0.0",
    "electron-vite": "^4.0.1",
    "eslint": "^10.2.0",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "electron-builder": "^26.8.1",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "patch-package": "^8.0.1",
    "react-devtools": "^7.0.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "build": {
    "appId": "com.nekocode.app",
    "productName": "Nekocode",
    "copyright": "Copyright © 2026 Nekocode",
    "directories": {
      "output": "dist",
      "buildResources": "resources"
    },
    "files": [
      "out/**/*",
      "!out/renderer/**/*.{map,js.map}",
      "!out/main/**/*.{map,js.map}",
      "!out/preload/**/*.{map,js.map}"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "resources",
        "filter": ["**/*"]
      },
      {
        "from": "patches",
        "to": "patches",
        "filter": ["**/*.patch"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "resources/icon.ico",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico",
      "installerHeaderIcon": "resources/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Nekocode",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "zip",
          "arch": ["x64", "arm64"]
        }
      ],
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "linux": {
      "target": ["AppImage"],
      "category": "Development"
    },
    "publish": {
      "provider": "github",
      "owner": "plsgivemeachane",
      "repo": "nekocode"
    }
  }
}
